# =========================
# OpenRouter (primary LLM)
# =========================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embedding model for RAG indexing / retrieval
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Main LLM for generation
OPENROUTER_LLM_MODEL=openai/gpt-oss-120b:free
OPENROUTER_LLM_FALLBACK_MODEL=inclusionai/ling-2.6-flash:free

# =========================
# Gemini (fallback LLM)
# =========================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_LLM_MODEL=gemini-2.0-flash

# =========================
# Retrieval
# =========================
RETRIEVAL_K=5
CHROMA_PERSIST_DIR=artifacts/chroma

# =========================
# Data
# =========================
KNOWLEDGE_DIR=data/knowledge

# =========================
# Backend
# =========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# =========================
# Frontend
# =========================
VITE_API_BASE_URL=http://localhost:8000
