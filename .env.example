# =========================
# OpenAI (primary LLM)
# =========================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_LLM_MODEL=gpt-4o

# =========================
# OpenRouter (embeddings + LLM fallback)
# =========================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embedding model for RAG indexing / retrieval
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Fallback LLM (used if OpenAI primary fails with a transient error)
OPENROUTER_LLM_FALLBACK_MODEL=inclusionai/ling-2.6-flash:free

# =========================
# Gemini (fallback LLM 2 — used if OpenRouter fallback also fails)
# =========================
GEMINI_API_KEY=your_gemini_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_LLM_MODEL=gemini-3-flash-preview

# =========================
# Retrieval
# =========================
RETRIEVAL_K=5
CHROMA_PERSIST_DIR=artifacts/chroma

# =========================
# Data
# =========================
KNOWLEDGE_DIR=data/knowledge

# =========================
# Backend
# =========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# =========================
# Frontend
# =========================
VITE_API_BASE_URL=http://localhost:8000
